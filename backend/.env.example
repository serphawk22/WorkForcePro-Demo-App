# Database - PostgreSQL (Required for both development and production)
# For local development with PostgreSQL installed via Homebrew:
DATABASE_URL=postgresql://YOUR_USERNAME@localhost/workforcepro
# For production (Railway PostgreSQL):
# DATABASE_URL=postgresql://username:password@host:port/database_name

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS Configuration
FRONTEND_URL=http://localhost:3000
PRODUCTION_FRONTEND_URL=https://your-app.vercel.app

# Environment
ENVIRONMENT=development
