# Database — pick ONE:
#
# A) Local SQLite (no Postgres install): uncomment below only
# SQLITE_DEV=1
#
# B) PostgreSQL — Docker (repo root: docker compose up -d):
# Example PostgreSQL URL — replace USER/PASSWORD/HOST/PORT/DB
# For Neon or hosted DBs include the full connection string with params.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/workforcepro
# Or Homebrew / your own:
# DATABASE_URL=postgresql://user@localhost/workforcepro

# JWT
SECRET_KEY=REDACTED_CHANGE_THIS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — frontend URL allowed to make requests
FRONTEND_URL=http://localhost:3000

# Optional: daily cron can POST /tasks/recurring/materialize with header X-Cron-Secret
CRON_SECRET=

# OpenAI (AI Assistant / chatbot)
OPENAI_API_KEY=REDACTED
OPENAI_API_KEY=

# Email automation
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USER=development.serphawk@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM_ADDRESS=development.serphawk@gmail.com
EMAIL_SUPPORT_ADDRESS=development.serphawk@gmail.com
SHEET_REMINDER_SCHEDULER_ENABLED=true
SHEET_REMINDER_TIME=21:00
SHEET_REMINDER_TIMEZONE=Asia/Kolkata
# Optional strict manual override format. Unmapped names do not receive email.
# EMPLOYEE_EMAIL_MAP={"employee name":"employee@example.com"}
EMPLOYEE_EMAIL_MAP=
