# Optional: set only when the UI should call the backend directly (e.g. Vercel → Railway).
# Leave UNSET during local `next dev` to use the built-in proxy: browser → /api/* → FastAPI (127.0.0.1:8000).
# NEXT_PUBLIC_API_URL=https://your-api.example.com

# Override backend target for the dev proxy (default: http://127.0.0.1:8000)
# BACKEND_PROXY_URL=http://127.0.0.1:8000

# If every route is still 404 in dev, copy these lines to .env.local (overrides .env.development):
# WATCHPACK_POLLING=true
# CHOKIDAR_USEPOLLING=true
# And run: ulimit -n 10240
